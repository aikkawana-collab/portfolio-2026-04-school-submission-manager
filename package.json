{
  "name": "school-submission-manager",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "npm run build:teacher && npm run build:student && npm run copy:html",
    "build:teacher": "vite build --config vite.config.teacher.ts",
    "build:student": "vite build --config vite.config.student.ts",
    "copy:html": "node scripts/copy-html.js",
    "push": "clasp push",
    "deploy": "npm run build && clasp push"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.15.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.7.3",
    "vite": "^6.1.0",
    "vite-plugin-singlefile": "^2.0.2"
  }
}
